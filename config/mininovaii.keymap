/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
    &kp N1      &kp N2      &kp N3     &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp COLON &kp ASTERISK   &kp DOT     &kp COMMA     &mo BOTH
    &kp N4      &kp N5      &kp N6     &zed_HDC          &zed_TC            &trans    &trans         &trans      &kp BACKSPACE
    &kp N7      &kp N8      &kp N9     &zed_MR           &zed_DC            &zed_SC   &kp UP_ARROW   &kp DOWN_ARROW
    &kp N0      &kp SPACE   &zed_ROW   &kp LEFT_ARROW    &kp RIGHT_ARROW
            >;
        };

