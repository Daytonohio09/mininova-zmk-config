            >;
        };*/

        both_layer {
            bindings = <
    &bt BT_SEL 0   &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_DISC 0 &bt BT_CLR  &trans  &trans  &trans &trans &out OUT_TOG
    &trans         &trans       &trans       &trans        &trans      &trans  &trans  &trans &trans
    &trans         &trans       &trans       &trans        &trans      &trans  &trans  &trans
    &out OUT_USB   &trans       &trans       &trans        &out OUT_BLE
            >;
        };

    };
};