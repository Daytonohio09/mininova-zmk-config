#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

#define DEFAULT  0
#define BOTH     1

// -----------------------------------
// | TAB:TAB |    |    |    |    |   -:-  =:=  <:<   |   (< = bksp)
// | ESC:ESC |    |    |    |    |    |   #:#   |
// |    |    |    |    |    |    |    |    |
//           |    |    |         |    |    |

/ {
    macros {
        // Define a name for your macro, preceded by a 'zed_' prefix by convention
        zed_SC: zed_SC {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(S) &kp LS(C)>
                ;
        };
        zed_DC: zed_DC {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(D) &kp LS(C)>
                ;
        };
        zed_HDC: zed_HDC {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(H) &kp LS(D) &kp LS(C)>
                ;
        };
        zed_TC: zed_TC {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(T) &kp LS(C)>
                ;
        };
        zed_MR: zed_MR {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp LS(M) &kp LS(R)>
                ;
        };
        zed_ROW: zed_ROW {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_tap &kp ENTER &kp LS(R) &kp LS(O) &kp LS(W) &kp SPACE &kp COLON>
                ;
        };
    };
};

